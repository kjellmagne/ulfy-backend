POSTGRES_USER=ulfy
POSTGRES_PASSWORD=replace-with-a-long-random-db-password
POSTGRES_DB=ulfy

JWT_SECRET=replace-with-a-long-random-jwt-secret
ACTIVATION_TOKEN_SECRET=replace-with-a-different-long-random-token-secret
CONFIG_SECRET_KEY=replace-with-a-32-byte-base64-or-hex-key
CORS_ALLOWED_ORIGINS=https://skrivdet.no,https://www.skrivdet.no
SWAGGER_ENABLED=true
SWAGGER_BASIC_AUTH_USERNAME=swagger-admin
SWAGGER_BASIC_AUTH_PASSWORD=replace-with-a-strong-swagger-password

# Public path served by APISIX. APISIX strips this prefix before proxying.
PUBLIC_BASE_PATH=/backend

# Pull prebuilt app images from GitHub Container Registry.
# The current registry package names still use the legacy ulfy-backend repo name.
SKRIVDET_API_IMAGE=ghcr.io/kjellmagne/ulfy-backend-api:latest
SKRIVDET_ADMIN_IMAGE=ghcr.io/kjellmagne/ulfy-backend-admin:latest

# Host directory for persistent PostgreSQL files when using docker-compose.ghcr.yml.
POSTGRES_DATA_DIR=/opt/ulfy-data/postgres
