POSTGRES_USER=ulfy
POSTGRES_PASSWORD=replace-with-a-long-random-db-password
POSTGRES_DB=ulfy

JWT_SECRET=replace-with-a-long-random-jwt-secret
ACTIVATION_TOKEN_SECRET=replace-with-a-different-long-random-token-secret

# The public HTTPS origin served by APISIX, without a trailing slash.
PUBLIC_BASE_URL=https://ulfy.example.com

# Pull prebuilt app images from GitHub Container Registry.
ULFY_API_IMAGE=ghcr.io/kjellmagne/ulfy-backend-api:latest
ULFY_ADMIN_IMAGE=ghcr.io/kjellmagne/ulfy-backend-admin:latest

# Host directory for persistent PostgreSQL files when using docker-compose.ghcr.yml.
POSTGRES_DATA_DIR=/opt/ulfy-data/postgres
