JWT_SECRET=replace-with-a-long-random-secret
ACTIVATION_TOKEN_SECRET=replace-with-a-different-long-random-secret
CONFIG_SECRET_KEY=replace-with-a-32-byte-base64-or-hex-key
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
SWAGGER_ENABLED=true
SWAGGER_BASIC_AUTH_USERNAME=
SWAGGER_BASIC_AUTH_PASSWORD=
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Empty for root/local Docker. Set to /backend only when an API gateway strips that prefix.
NEXT_PUBLIC_BASE_PATH=
TEMPLATE_REPOSITORY_API_KEY=
TEMPLATE_PREVIEW_PROVIDER_TYPE=openai-compatible
TEMPLATE_PREVIEW_ENDPOINT_URL=
TEMPLATE_PREVIEW_API_KEY=
TEMPLATE_PREVIEW_MODEL=
